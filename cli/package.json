{
  "name": "@mocca/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "mocca-cli": "dist/index.js"
  },
  "scripts": {
    "build": "npm run build:ts && npm run build:pty",
    "build:ts": "tsc -p tsconfig.json",
    "build:pty": "node scripts/pty-cargo.mjs build",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:pty": "node scripts/pty-cargo.mjs test"
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.14.19",
    "chokidar": "^5.0.0",
    "fast-glob": "^3.3.3",
    "ignore": "^7.0.5",
    "jsonc-parser": "^3.3.1",
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/ws": "^8.18.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  },
  "engines": {
    "node": ">=20"
  }
}
